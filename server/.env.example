# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/videosite

# Cloudflare R2
# Dashboard → R2 → Manage R2 API Tokens → Account ID (sağ üst)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name

# CDN URL — Bunny CDN veya R2 public domain
# R2 public URL: https://pub-<hash>.r2.dev  YA DA  özel Bunny CDN
CDN_URL=https://poredasite.b-cdn.net

# Admin
ADMIN_PASSWORD=supersecretpassword123

# Client URL (CORS & sitemap)
CLIENT_URL=http://localhost:5173
